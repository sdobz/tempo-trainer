#!/bin/bash
# Lint code with Deno
set -e

# Re-enter via nix develop if not already in a nix shell
if [[ -z "$IN_NIX_SHELL" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
  exec nix develop "$PROJECT_ROOT" -c "$0" "$@"
fi

echo "🔍 Linting code..."

# If arguments provided, lint only those files
# Otherwise lint everything
if [[ $# -gt 0 ]]; then
  deno lint "$@"
else
  deno lint src/
fi

echo "✅ Linting passed"
