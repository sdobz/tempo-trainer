#!/bin/bash
# Type check JavaScript with TypeScript
set -e

# Re-enter via nix develop if not already in a nix shell
if [[ -z "$IN_NIX_SHELL" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
  exec nix develop "$PROJECT_ROOT" -c "$0"
fi

echo "📋 Type checking..."
tsc --noEmit --allowJs --checkJs --esModuleInterop --skipLibCheck \
  src/**/*.js index.html

echo "✅ Type check passed"
