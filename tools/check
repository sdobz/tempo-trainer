#!/bin/bash
# Type check with Deno
set -e

# Re-enter via nix develop if not already in a nix shell
if [[ -z "$IN_NIX_SHELL" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
  exec nix develop "$PROJECT_ROOT" -c "$0" "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$PROJECT_ROOT"

echo "📋 Type checking..."

# If arguments provided, check only those files
# Otherwise check everything
if [[ $# -gt 0 ]]; then
  deno check "$@"
else
  deno check src/**/*.{ts,js}
fi

echo "✅ Type check passed"
